# ─── Lattice SDK — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the Lattice Privacy Proxy.
# Default: http://localhost:8080/v1  (local proxy for development)
# Production example: https://proxy.your-company.com/v1
LATTICE_PROXY_URL=http://localhost:8080/v1

# API key forwarded to the proxy (and ultimately to the LLM provider).
# If LATTICE_API_KEY is not set, the SDK falls back to OPENAI_API_KEY.
LATTICE_API_KEY=your-api-key-here

# (Optional) Standard OpenAI key — used as fallback when LATTICE_API_KEY
# is not present. Useful for zero-config migrations from plain openai usage.
# OPENAI_API_KEY=sk-...
